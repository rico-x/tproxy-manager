#!/bin/sh
# Idempotent defaults for OpenWrt UCI

set -e

# --- /etc/tproxy-manager: каталог и пустые файлы только если их нет ---
mkdir -p /etc/tproxy-manager
for f in \
  /etc/tproxy-manager/tproxy-manager.ports \
  /etc/tproxy-manager/tproxy-manager.v4 \
  /etc/tproxy-manager/tproxy-manager.v6 \
  /etc/tproxy-manager/tproxy-manager.src4.only \
  /etc/tproxy-manager/tproxy-manager.src6.only \
  /etc/tproxy-manager/tproxy-manager.src4.bypass \
  /etc/tproxy-manager/tproxy-manager.src6.bypass \
  /etc/tproxy-manager/geo-sources.conf \
  /etc/tproxy-manager/watchdog.links
do
  [ -e "$f" ] || : > "$f"
done

if [ ! -e /etc/tproxy-manager/watchdog-outbound.template.jsonc ] && [ -f /usr/share/tproxy-manager/watchdog-outbound.template.jsonc ]; then
  cp /usr/share/tproxy-manager/watchdog-outbound.template.jsonc /etc/tproxy-manager/watchdog-outbound.template.jsonc
fi

if [ ! -e /etc/tproxy-manager/watchdog-test-config.template.jsonc ] && [ -f /usr/share/tproxy-manager/watchdog-test-config.template.jsonc ]; then
  cp /usr/share/tproxy-manager/watchdog-test-config.template.jsonc /etc/tproxy-manager/watchdog-test-config.template.jsonc
fi

# --- UCI доступен? ---
command -v uci >/dev/null 2>&1 || exit 0

# На случай полностью отсутствующих файлов конфигов (безопасно):
for c in tproxy-manager tproxy-manager; do
  [ -f "/etc/config/$c" ] || touch "/etc/config/$c"
done

# --- UCI helpers ---
# set_default <cfg> <section> <option> <value>
set_default() {
  local cfg="$1" sec="$2" opt="$3" val="$4"
  if ! uci -q get "$cfg.$sec.$opt" >/dev/null 2>&1; then
    uci set "$cfg.$sec.$opt=$val"
  fi
}

# ensure_section <cfg> <section_name> <type>
ensure_section() {
  local cfg="$1" sec="$2" typ="$3"
  # Универсально: создаёт пакет и именованную секцию при отсутствии
  uci set "$cfg.$sec=$typ"
}

# --- tproxy-manager (наш UCI) ---
ensure_section tproxy-manager main main
set_default tproxy-manager main log_enabled        '1'
set_default tproxy-manager main nft_table          'tp_mgr'
set_default tproxy-manager main ifaces             'br-lan'
set_default tproxy-manager main ipv6_enabled       '1'
set_default tproxy-manager main tproxy_port        '61219'
set_default tproxy-manager main fwmark_tcp         '0x1'
set_default tproxy-manager main fwmark_udp         '0x2'
set_default tproxy-manager main rttab_tcp          '100'
set_default tproxy-manager main rttab_udp          '101'
set_default tproxy-manager main port_mode          'bypass'
set_default tproxy-manager main ports_file         '/etc/tproxy-manager/tproxy-manager.ports'
set_default tproxy-manager main bypass_v4_file     '/etc/tproxy-manager/tproxy-manager.v4'
set_default tproxy-manager main bypass_v6_file     '/etc/tproxy-manager/tproxy-manager.v6'
set_default tproxy-manager main src_mode           'off'
set_default tproxy-manager main src_only_v4_file   '/etc/tproxy-manager/tproxy-manager.src4.only'
set_default tproxy-manager main src_only_v6_file   '/etc/tproxy-manager/tproxy-manager.src6.only'
set_default tproxy-manager main src_bypass_v4_file '/etc/tproxy-manager/tproxy-manager.src4.bypass'
set_default tproxy-manager main src_bypass_v6_file '/etc/tproxy-manager/tproxy-manager.src6.bypass'
set_default tproxy-manager main enable_watchdog    '0'
set_default tproxy-manager main watchdog_check_url 'https://ifconfig.me/ip'
set_default tproxy-manager main watchdog_proxy_url 'socks5h://127.0.0.1:10808'
set_default tproxy-manager main watchdog_interval  '60'
set_default tproxy-manager main watchdog_fail_threshold '3'
set_default tproxy-manager main watchdog_connect_timeout '15'
set_default tproxy-manager main watchdog_max_time  '20'
set_default tproxy-manager main watchdog_links_file '/etc/tproxy-manager/watchdog.links'
set_default tproxy-manager main watchdog_template_file '/etc/tproxy-manager/watchdog-outbound.template.jsonc'
set_default tproxy-manager main watchdog_outbound_file '/etc/xray/04_outbounds.json'
set_default tproxy-manager main watchdog_vless2json '/usr/bin/vless2json.sh'
set_default tproxy-manager main watchdog_service_path '/etc/init.d/xray'
set_default tproxy-manager main watchdog_restart_cmd 'restart'
set_default tproxy-manager main watchdog_test_command '/usr/bin/xray -c {config}'
set_default tproxy-manager main watchdog_test_template_file '/etc/tproxy-manager/watchdog-test-config.template.jsonc'
set_default tproxy-manager main watchdog_selection_mode 'random'
set_default tproxy-manager main watchdog_exclude_dead '0'
set_default tproxy-manager main watchdog_dead_cooldown_hours '0'
set_default tproxy-manager main watchdog_dead_cooldown_minutes '0'
set_default tproxy-manager main watchdog_test_port '10881'
set_default tproxy-manager main watchdog_background_check_enabled '0'
set_default tproxy-manager main watchdog_background_check_interval '1800'
uci commit tproxy-manager

exit 0
